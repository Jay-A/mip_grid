#!/bin/bash

# -------------------------------------------------------
# mip_grid environment (HPC + non-module fallback)
# -------------------------------------------------------

if command -v module >/dev/null 2>&1; then
    USE_MODULES=1
else
    USE_MODULES=0
fi

# -------------------------------------------------------
# Compiler / MPI / HDF5 defaults (fallback path)
# -------------------------------------------------------

export CC=${CC:-mpicc}
export CXX=${CXX:-mpicxx}

export HDF5_MODE=${MIP_GRID_HDF5_MODE:-serial}

# -------------------------------------------------------
# Module-based environment
# -------------------------------------------------------

if [ "$USE_MODULES" -eq 1 ]; then
    module purge

    module load StdEnv 2>/dev/null

    module load gcc/12.1.1
    module load openmpi/4.1.2

    if [ "$HDF5_MODE" = "parallel" ]; then
        module load hdf5-parallel/1.14.0 || {
            echo "[error] hdf5-parallel not available"
            exit 1
        }
    else
        module load hdf5-serial/1.14.0 || {
            echo "[error] hdf5-serial not available"
            exit 1
        }
    fi

else
    # ---------------------------------------------------
    # Non-module fallback (local / CI / Docker)
    # ---------------------------------------------------

    echo "[mip_grid] No module system detected — using system environment"

    # You must ensure these are installed in PATH
    command -v mpicc >/dev/null || echo "[warn] mpicc not found in PATH"
    command -v mpicxx >/dev/null || echo "[warn] mpicxx not found in PATH"
    command -v h5cc >/dev/null || echo "[warn] HDF5 not found in PATH"

    # Optional: allow explicit overrides
    export HDF5_ROOT=${HDF5_ROOT:-/usr/local/hdf5}

fi

# -------------------------------------------------------
# Final summary
# -------------------------------------------------------

echo "[mip_grid] Environment configured:"
echo "  MPI compiler: $CC / $CXX"
echo "  HDF5 mode: $HDF5_MODE"
echo "  Module system: $USE_MODULES"