#---------------------------------------------------------------------------
# Project metadata
#---------------------------------------------------------------------------
PROJECT_NAME           = "Synthetic Grid API"
PROJECT_BRIEF          = "Header and source-level documentation for synthetic power grid simulation"
PROJECT_NUMBER         = "1.0"
OUTPUT_DIRECTORY       = ../docs
CREATE_SUBDIRS         = YES

#---------------------------------------------------------------------------
# Input files
#---------------------------------------------------------------------------
INPUT                  = ../cpp/include
FILE_PATTERNS          = *.h # *.cpp    # Include .cpp later by removing comment
RECURSIVE              = YES
EXCLUDE                = 

#---------------------------------------------------------------------------
# Source browsing & extraction
#---------------------------------------------------------------------------
EXTRACT_ALL            = YES       # full internal visibility
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
EXTRACT_LOCAL_METHODS  = YES
EXTRACT_ANON_NSPACES   = YES

#---------------------------------------------------------------------------
# Build settings
#---------------------------------------------------------------------------
GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO
GENERATE_MAN           = NO
GENERATE_RTF           = NO
GENERATE_XML           = YES        # For Sphinx/Breathe integration
XML_OUTPUT             = xml        # for sphinx/breathe
FULL_PATH_NAMES        = NO
STRIP_FROM_PATH        = ../cpp/include

#---------------------------------------------------------------------------
# Appearance
#---------------------------------------------------------------------------
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES

#---------------------------------------------------------------------------
# Cross-references
#---------------------------------------------------------------------------
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
USE_MDFILE_AS_MAINPAGE = ../../README.md   # adjust path to your repo root

#---------------------------------------------------------------------------
# Source code highlighting
#---------------------------------------------------------------------------
SOURCE_BROWSER         = YES
INLINE_SOURCES         = YES
VERBATIM_HEADERS       = YES

#---------------------------------------------------------------------------
# Input encoding
#---------------------------------------------------------------------------
INPUT_ENCODING         = UTF-8
